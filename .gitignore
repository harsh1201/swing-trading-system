# Persistent storage and cache
data/
!data/
data/*
!data/symbols.py
storage/
*.csv
*.json
!config/stocks.json  # Keep stock list if it was json, but it's .py here
# Track the trained ML models — they must travel with every deploy, otherwise the
# quality gate silently degrades to score-only (see ADR-003 P1).
!models/
!models/*.json

# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd

# Local development environments
venv/
.venv/
env/
.env

# Editor settings
.vscode/

# Static types/cache
.mypy_cache/
.pytest_cache/
